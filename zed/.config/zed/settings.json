{
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "model_parameters": [],
  },
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "terminal": {
    "env": {},
    "font_family": "JetBrainsMono Nerd Font Mono",
    "line_height": {
      "custom": 1.0,
    },
    "dock": "right",
    "cursor_shape": "underline",
    "blinking": "on",
  },
  "project_panel": {
    "sticky_scroll": false,
    "auto_fold_dirs": false,
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show": false,
    "show_tab_bar_buttons": false,
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
    "runnables": true,
    "folds": false,
  },
  "minimap": {
    "show": "never",
  },
  "scrollbar": {
    "axes": {
      "horizontal": false,
      "vertical": false,
    },
  },
  "cursor_shape": "underline",
  "cursor_blink": true,
  "autosave": "on_focus_change",
  "buffer_font_family": "JetBrainsMono Nerd Font Mono",
  "file_types": {
    "json": ["*.excalidraw", "*.excalidrawlib"],
    "dotenv": [".env*"],
    "javascript": ["*.dbclient-js"],
    "javascriptreact": ["*.jsx"],
    "scala": ["*.scala"],
    "markdown": ["*.mdx", ".md"],
  },
  "use_on_type_format": true,
  "indent_guides": {
    "enabled": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 13,
  "theme": {
    "mode": "system",
    "light": "Gruvbox Dark",
    "dark": "Ayu Dark",
  },
}
